{
  "name": "telegram-media-downloader",
  "version": "2.3.20",
  "description": "Self-hosted Telegram media downloader — CLI + Web dashboard. MIT, no quotas.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "telegram-downloader": "src/index.js"
  },
  "files": [
    "src",
    "scripts",
    "runner.js",
    "watchdog.ps1",
    "Dockerfile",
    "docker-compose.yml",
    "config.example.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "menu": "node src/index.js menu",
    "monitor": "node src/index.js monitor",
    "history": "node src/index.js history",
    "auth": "node src/index.js auth",
    "prod": "node runner.js",
    "dev": "node --watch src/web/server.js",
    "migrate": "node scripts/migrate_json_to_sqlite.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,html,css}\" \"*.{md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/botnick/telegram-media-downloader.git"
  },
  "homepage": "https://github.com/botnick/telegram-media-downloader#readme",
  "bugs": {
    "url": "https://github.com/botnick/telegram-media-downloader/issues"
  },
  "keywords": [
    "telegram",
    "downloader",
    "media-downloader",
    "telegram-stories",
    "scraper",
    "backup",
    "channel-backup",
    "gramjs",
    "self-hosted",
    "automation",
    "telegram-api"
  ],
  "author": "botnick",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "telegram": "^2.19.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "vitest": "^2.1.4"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{html,css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
